generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING_REVIEW
  DELIVERED
  INVOICED
  PAID
}

enum BillingStatus {
  NOT_BILLED
  BILLING_PLANNED
  BILLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

model Client {
  id        String    @id @default(cuid())
  name      String    @unique
  email     String?
  phone     String?
  address   String?
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id             String         @id @default(cuid())
  title          String
  amount         Int            @default(0)
  dueDate        DateTime?
  status         ProjectStatus  @default(NOT_STARTED)
  billingStatus  BillingStatus  @default(NOT_BILLED)
  paymentStatus  PaymentStatus  @default(UNPAID)
  memo           String?
  fileUrl        String?
  referenceUrl   String?
  clientId       String
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks          Task[]
  invoices       Invoice[]
  deliveryNotes  DeliveryNote[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([billingStatus])
  @@index([paymentStatus])
  @@index([dueDate])
}

model Task {
  id          String    @id @default(cuid())
  title       String
  dueDate     DateTime?
  completed   Boolean   @default(false)
  memo        String?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId])
  @@index([completed])
}

model Invoice {
  id          String    @id @default(cuid())
  issueDate   DateTime  @default(now())
  dueDate     DateTime?
  subtotal    Int
  tax         Int
  total       Int
  payee       String?
  note        String?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DeliveryNote {
  id          String    @id @default(cuid())
  issueDate   DateTime  @default(now())
  note        String?
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model BusinessSetting {
  id             String   @id @default("default")
  businessName   String   @default("")
  ownerName      String   @default("")
  postalCode     String?
  address        String?
  phone          String?
  email          String?
  invoicePrefix  String   @default("INV")
  bankName       String?
  bankBranch     String?
  bankAccount    String?
  bankHolder     String?
  taxRate        Int      @default(10)
  invoiceNote    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
